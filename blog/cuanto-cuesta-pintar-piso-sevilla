/* ── RESET & TOKENS ── */
:root{
  --gd:#0f2d22; --gm:#1a5c3a; --gl:#2e7d52; --gp:#e6f2ec;
  --go:#c9a84c; --gol:#e8c97a;
  --white:#fff; --off:#f7f6f3;
